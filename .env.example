# Fluent installation and license
BOFM_ANSYS_ROOT=/ansys_inc/v242
ANSYSLMD_LICENSE_FILE=1055@license-server

# Windows-only CAD generation
BOFM_SPACECLAIM_EXE=D:\Ansys\ANSYS Inc\v242\scdm\SpaceClaim.exe

# External binary template; copy separately because Git excludes SCDOC files
BOFM_C3X_TEMPLATE=/srv/bofm-assets/c3x_kumar_fixed_le_template.scdoc

# Optional overrides for compact geometry records already included in Git
# BOFM_C3X_BASE_DESIGN=/path/to/c3x_nasa44344_periodic_v2_design.json
# BOFM_C3X_BOUNDARY_TARGETS=/path/to/c3x_boundary_targets.json
